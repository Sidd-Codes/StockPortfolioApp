@if (User.Identity.IsAuthenticated)
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" href="/Identity/Account/Manage">
                <i class="fas fa-user me-1"></i>Hello @User.Identity.Name!
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/Identity/Account/Logout">
                <i class="fas fa-sign-out-alt me-1"></i>Logout
            </a>
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" href="/Identity/Account/Register">
                <i class="fas fa-user-plus me-1"></i>Register
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/Identity/Account/Login">
                <i class="fas fa-sign-in-alt me-1"></i>Login
            </a>
        </li>
    </ul>
}
